[Unit]
Description=BUS287 BMA camera-only relay
After=network-online.target tailscaled.service
Wants=network-online.target

[Service]
Type=simple
ExecStart=%h/bin/buswatch-camera-relay -camera-relay -addr 127.0.0.1:8187
Restart=always
RestartSec=5
Nice=10
CPUQuota=10%
MemoryMax=64M
TasksMax=32
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=read-only
ProtectSystem=strict
RestrictAddressFamilies=AF_INET AF_INET6

[Install]
WantedBy=default.target
